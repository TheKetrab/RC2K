@rendermode InteractiveServer

@page "/admin/cron-messages"

@inject ICronMessageService CronMessageService

@using System.Collections.Generic

<MudTable Items="@_messages" MultiSelection="true" Hover="true" Breakpoint="Breakpoint.Sm">
    <ToolBarContent>
        <MudText Typo="Typo.h6">Cron Messages</MudText>
        <MudSpacer />
    </ToolBarContent>
    <HeaderContent>
        <MudTh>Published</MudTh>
        <MudTh>Cron</MudTh>
        <MudTh>Message</MudTh>
    </HeaderContent>
    <RowTemplate>
        <MudTd DataLabel="Published">@context.Published</MudTd>
        <MudTd DataLabel="Cron">@context.Cron</MudTd>
        <MudTd DataLabel="Message">@context.Message</MudTd>
    </RowTemplate>
    <PagerContent>
        <MudTablePager />
    </PagerContent>
</MudTable>

@code {

    private List<CronMessage> _messages = [];

    protected override async Task OnInitializedAsync()
    {
        _messages = await CronMessageService.GetAll();
    }
}