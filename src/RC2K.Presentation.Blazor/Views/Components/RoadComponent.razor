@rendermode InteractiveServer

<style>
    .gravel {
        background-image:
            radial-gradient(#bbb 1px, transparent 0),
            radial-gradient(#999 1px, transparent 0);
        background-size: 4px 4px, 7px 7px;
        background-position: 0 0, 2px 2px;
        background-color: #aaa;
        opacity: 0.9;
        color: var(--gray100);
    }

    .dirt {
        background:
            radial-gradient(ellipse at 30% 20%, #3e2723 10%, transparent 40%),
            radial-gradient(circle at 70% 60%, #5d4037 5%, transparent 30%),
            repeating-linear-gradient(45deg, transparent 0, transparent 2px, rgba(0,0,0,0.1) 2px, rgba(0,0,0,0.1) 4px),
            linear-gradient(135deg, #4e342e 0%, #3e2723 100%);
        background-size:
            80px 120px,
            150px 150px,
            4px 4px,
            100% 100%;
        color: #a9826a;
    }

    .asphalt {
        background: 
            repeating-linear-gradient(45deg, #333 0px, #333 1px, transparent 1px, transparent 3px),
            repeating-linear-gradient(-45deg, #222 0px, #222 1px, transparent 1px, transparent 4px),
            linear-gradient(rgba(0,0,0,0.2), rgba(0,0,0,0.2));
        background-color: #444;
        background-size: 4px 4px, 6px 6px, 100% 100%;
        color: var(--gray400);
    }

    .snow {
        background:
            radial-gradient(circle at 20% 30%, #fff 10%, transparent 50%),
            radial-gradient(circle at 80% 70%, #f0faff 20%, transparent 60%),
            linear-gradient(135deg, #ffffff 0%, #f2f7ff 100%);
        background-size: 100px 100px, 150px 150px, 100% 100%;
        background-color: #fff;
        box-shadow: inset 0 0 50px rgba(200, 230, 255, 0.3);
        color: var(--gray700);
    }


</style>

@code
{
    [Parameter] public int[] Pieces { get; set; } = [];
    [Parameter] public string[] Colors { get; set; } = [];
}

<div style="display: flex; width: 100%;">

    @for (int i = 0; i < Pieces.Length; i++)
    {
        if (Pieces[i] > 0)
        {
            <div class="d-flex align-center justify-center @Colors[i]"
                 style="width: @(Pieces[i])%; min-width: 3ch; height: 100%; font-weight: bold; white-space: nowrap;">
                <span>@(Pieces[i])%</span>
            </div>
        }
    }
</div>