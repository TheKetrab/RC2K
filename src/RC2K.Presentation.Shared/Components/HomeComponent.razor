@using Microsoft.Extensions.Configuration
@using System.Reflection
@inject IConfiguration Config

<PageTitle>Home</PageTitle>

<style>
    .content {
        margin-top: 0 !important;
        padding: 0 !important;
        padding-top: 0 !important;
    }


    .emph {
        color: var(--primary);
        font-weight: bold;
    }

    .emph2 {
        color: var(--secondary);
        font-weight: bold;
    }



</style>

<div style="@($@"
     background-image: url(_content/RC2K.Presentation.Shared/img/home/home{DayTime}.png);
     background-size: cover;
     background-position-x: center;
     
     min-height: clamp(400px, calc(100vh - var(--header-margin-top) - var(--header-height) - var(--bottom-banner-height)), 1000px);
     padding-top: 80px;
     display: flex;
     flex-direction: column;
     justify-content: space-between;
     ")">

    <Banner />

    <div style="align-self: flex-end; color: rgb(255 255 255 / 75%); font-family: Anta; padding-right: 5px;">
        @AppVersion
    </div>

</div>

<style>

    .bottom-banner {

        height: var(--bottom-banner-height);
        padding: 10px 15px;
        font-size: 12pt;
        border-radius: 0;
        font-family: Anta, sans-serif;

        background: linear-gradient(90deg, #272727cf, rgb(37 37 37), rgb(30 30 30), rgb(30 30 30 / 71%));
        border-top: 1px solid rgba(255, 204, 0, 0.3);
        border-bottom: 1px solid rgba(255, 204, 0, 0.3);
    }

    .bottom-banner-content {
        height: 100%;
        border-top: 1px solid rgba(255, 204, 0, 0.3);
        border-bottom: 1px solid rgba(255, 204, 0, 0.3);
        place-content: center;
    }

    .bottom-banner-content > p {
        text-align: center;
        color: white;
    }

</style>

<div class="bottom-banner">
    <div class="bottom-banner-content">
        <p>„With nearly <span class="emph2">2,000 unique classifications</span> to conquer,<br /> there is always a new record to break.”</p>
        <p><span class="emph2">In which one will you prove to be the best?</span></p>
    </div>

</div>

<HomeSubpage2 />

<HomeSubpage3 />

<HomeSubpage4 />

@code {
    private static string AppVersion
    {
        get
        {
            var raw = Assembly.GetEntryAssembly()
                ?.GetCustomAttribute<AssemblyInformationalVersionAttribute>()
                ?.InformationalVersion ?? "?";
            // strip +gitsha suffix that the SDK appends in source-controlled builds
            var plus = raw.IndexOf('+');
            return "v" + (plus >= 0 ? raw[..plus] : raw);
        }
    }

    public int DayTime
    {
        get
        {
            int now = DateTime.Now.Hour;
            return now switch
            {
                >= 0 and < 11 => 1,
                >= 11 and < 16 => 2,
                >= 16 and < 20 => 3,
                _ => 4
            };
        }
    }
}