@using Microsoft.Extensions.Configuration
@inject IConfiguration Config

<PageTitle>Home</PageTitle>

<style>
    .content {
        margin-top: 0 !important;
        padding: 0 !important;
        padding-top: 0 !important;
    }


    .emph {
        color: var(--primary);
        font-weight: bold;
    }

    .emph2 {
        color: var(--secondary);
        font-weight: bold;
    }



</style>

<div style="@($@"
     background-image: url(_content/RC2K.Presentation.Shared/img/home/home{DayTime}.png);
     background-size: cover;
     background-position-x: center;

     min-height: clamp(400px, calc(100vh - var(--header-margin-top) - var(--header-height) - var(--bottom-banner-height)), 1000px);
     padding-top: 80px;
     display: flex;
     flex-direction: column;
     justify-content: space-between;
     ")">

        <Banner />

    <div style="align-self: flex-end; color: rgb(255 255 255 / 75%); font-family: Anta; padding-right: 5px;">
        v1.2.0-static
</div>

</div>

<style>

    .bottom-banner {

        height: var(--bottom-banner-height);
        padding: 10px 15px;
        font-size: 12pt;
        border-radius: 0;
        font-family: Anta, sans-serif;

        background: linear-gradient(90deg, #272727cf, rgb(37 37 37), rgb(30 30 30), rgb(30 30 30 / 71%));
        border-top: 1px solid rgba(255, 204, 0, 0.3);
        border-bottom: 1px solid rgba(255, 204, 0, 0.3);
    }

    .bottom-banner-content {
        height: 100%;
        border-top: 1px solid rgba(255, 204, 0, 0.3);
        border-bottom: 1px solid rgba(255, 204, 0, 0.3);
        place-content: center;
    }

    .bottom-banner-content > p {
        text-align: center;
        color: white;
    }

</style>

<div class="bottom-banner">
    <div class="bottom-banner-content">
        <p>„With nearly <span class="emph2">2,000 unique classifications</span> to conquer,<br /> there is always a new record to break.”</p>
        <p><span class="emph2">In which one will you prove to be the best?</span></p>
    </div>

</div>

<HomeSubpage2 />

<MudDivider />

<HomeSubpage3 />

<MudDivider />

<MudContainer MaxWidth="MaxWidth.Large" Class="mt-8">
    <MudText Typo="Typo.h4" GutterBottom="true">Interactive Stage Maps</MudText>
    <MudText Typo="Typo.body1" Class="mb-4">
        Experience the realism of <em>Rally Championship 2000</em> like never before. Those stages aren't just pixels — they are real-world locations preserved in history.
    </MudText>

    <MudPaper Outlined="true" Class="pa-4 mb-4" Style="background-color: rgba(255,255,255,0.02);">    
        <MudStack Spacing="3">
            <div class="d-flex">
                <MudIcon Icon="@Icons.Material.Filled.Search" Color="Color.Primary" Class="me-3" />
                <div>
                    <MudText Typo="Typo.body1"><strong>Real-World Discovery:</strong></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        In 2018 <span style="color: var(--primary300);">anonimowy1121</span> identified the original rally stages within Google Maps coordinates and presented them <a href="https://rc2000.forumotion.com/t27-localisations-maps-of-the-stages-on-google-maps-lokalizacje-mapy-etapow-na-google-maps">on the forum</a>.
                    </MudText>
                </div>
            </div>

            <div class="d-flex">
                <MudIcon Icon="@Icons.Material.Filled.Map" Color="Color.Primary" Class="me-3" />
                <div>
                    <MudText Typo="Typo.body1"><strong>Digital Reconstruction:</strong></MudText>
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        In 2025 <span style="color: var(--primary300);">TheKetrab</span> moved found coordinates to interactive maps that trace the routes through terrain where standard roads don't even exist on Google Maps.
                    </MudText>
                </div>
            </div>
        </MudStack>
    </MudPaper>

    <div style="display: flex; justify-content: space-around;">
        <img style="max-height: 300px;" src="_content/RC2K.Presentation.Shared/img/home/stage-map/SC_004.PNG" />
        <img style="max-height: 300px;" src="_content/RC2K.Presentation.Shared/img/home/stage-map/gmap.jpg" />
        <img style="max-height: 300px;" src="_content/RC2K.Presentation.Shared/img/home/stage-map/osm.jpg" />
    </div>

    <MudGrid Justify="Justify.FlexEnd">
        <MudItem xs="12" sm="3">
            <MudButton Variant="Variant.Filled"
                       Class="ma-4"
                       Href="@($"{Config["AppBaseUrl"]}/stages")"
                       Color="Color.Primary"
                       FullWidth="true"
                       EndIcon="@Icons.Material.Filled.Explore"
                       Size="Size.Large">
                Explore Maps
            </MudButton>
        </MudItem>
    </MudGrid>
</MudContainer>
 
@code {
    public int DayTime
    {
        get
        {
            int now = DateTime.Now.Hour;
            return now switch
            {
                >= 0 and < 11 => 1,
                >= 11 and < 16 => 2,
                >= 16 and < 20 => 3,
                _ => 4
            };
        }
    }
}