@using Microsoft.Extensions.Configuration
@using Microsoft.JSInterop
@inject IConfiguration Config

<style>

    h1 {
        margin-top: 3rem;
        margin-bottom: 30px;
        font-size: 48px;
        font-family: "Viga", sans-serif;
        line-height: 56px;
    }

    .page-card-2-info h2 {
        line-height: 1.3;
        margin-top: 20px;
        margin-bottom: 20px;
        font-size: 28px;
        font-family: "Viga", sans-serif;
    }

    .page-card-2 > h3 {
        opacity: 0.8;
    }

    h3,
    h4 {
        font-family: "Roboto", sans-serif;
    }

    .page-card-2 > *:not(:last-child) {
        margin-left: 3rem;
        margin-right: 3rem;
    }

    .page-card-2 {

        --move-x: 7px;
        --move-y: -7px;

        min-height: calc(100vh - var(--header-height));
        display: flex;
        flex-direction: column;

        background:
             radial-gradient(ellipse 70% 40% at right top, transparent, white)
            , radial-gradient(circle, transparent 20%, #e5e5f7 20%, #e5e5f7 80%, transparent 80%, transparent)
            , radial-gradient(circle, transparent 20%, #e5e5f7 20%, #e5e5f7 80%, transparent 80%, transparent)
            , linear-gradient(#444cf7 2px, transparent 2px)
            , linear-gradient(90deg, #444cf7 2px, #e5e5f7 2px);
        
        background-size:
            100% 100%
            , 50px 50px
            , 50px 50px
            , 25px 25px
            , 25px 25px;
        
        background-position:
            0 0
            , var(--move-x) var(--move-y)
            , calc(25px + var(--move-x)) calc(25px + var(--move-y))
            , var(--move-x) calc(-1px + var(--move-y))
         , calc(-1px + var(--move-x)) var(--move-y);
        
        background-repeat:
            no-repeat
            , repeat
            , repeat
            , repeat
            , repeat;

    }

    .page-card-2 > div:first-child {
        background: red;
    }

    .page-card-2 > h1 {
        max-width: 1000px;
    }

    .page-card-2-img {
        flex-grow: 1;
        border-bottom-left-radius: 25px;
        overflow: hidden;
        margin: 20px;

        transition: transform .75s ease, opacity .5s ease;
        transition-delay: .25s;
        opacity: 0;
        transform: rotate(-360deg) scale(0,0);
        
    }

    .page-card-2-img > img {
        
        object-fit: contain;
        mask-image: linear-gradient(90deg, black 90%, transparent 100%);

    }

    .page-card-2-info {
        padding: 10px 30px;
        max-width: 55%;
        box-shadow: rgb(0 0 0 / 30%) 0px 0px 10px;
        background-color: #F0F0F0;
        border-radius: 25px;
    }

    .page-card-2-bottom-info {
        flex-grow: 1;
        display: flex;
        flex-direction: column;
        gap: 1em;
        background:
            linear-gradient(transparent, transparent 75%, gray);
    }

    .page-card-2-bottom-info > h2 {
        text-align: center;
        font-size: 2em;
    }
    .page-card-2-bottom-info > p {
            padding: 0 5em;
            font-family: 'Roboto';
            font-size: 20px;
            text-align: center;
        }

    .page-card-2-middle {
        display: flex;
        margin: 50px 0;
        gap: 3em;
    }

    .page-card-2-info-card > header {
        gap: .5em;
        display: flex;
        align-items: center;
        margin-bottom: 10px;
    }

    .page-card-2-info-card {
        margin-top: 10px;
    }

    .page-card-2-info-card > ul {
            padding-left: 3ch;
            padding-right: 10px;
            margin: 5px;
    }

    .page-card-2-info-card:first-child > ul {
        border-right: solid 1px black;
    }

    .touched .page-card-2-img {
        transform: rotate(0deg) scale(1,1);
        opacity: 1;
    }

    li {
        margin-block: 5px;
    }
    li::marker {
        content: '>  ';
    }

</style>

<div class="page-card-2">

    <h1>
        Site dedicated for fans of Mobil&nbsp;1&nbsp;Rally&nbsp;Championship&nbsp;2000
    </h1>
    <h3>
        Our database features the full list of <MudLink Href="@($"{Config["AppBaseUrl"]}/stages")">72 official stages</MudLink> known as simulation & arcade versions.
    </h3>
    <div @ref=midElement class="page-card-2-middle">
        <div class="page-card-2-img">
            <img src="_content/RC2K.Presentation.Shared/img/home/home-page2.png" />
        </div>
        <div class="page-card-2-info">
            <h2>Just upload a time entry or have a full profile, the choice is yours</h2>
            <div style="display: flex; gap: 5px;">
                <div class="page-card-2-info-card">
                    <header>
                        <MudIcon Icon="@Icons.Material.Filled.PersonOutline" />
                        <h3>Guest drivers</h3>
                    </header>
                    <ul>
                        <li>No registration required</li>
                        <li>Just provide a nickname to receive a unique access token for future uploads</li>
                        <li>Without an account you are able to surf among all tracks and view top 20 times in general classification in order to compare them with your pb!</li>
                    </ul>
                </div>
                <div class="page-card-2-info-card">
                    <header>
                        <MudIcon Icon="@Icons.Material.Filled.VerifiedUser" />
                        <h3>Registered members</h3>
                    </header>
                    <ul>
                        <li>Create an account to unlock full classification</li>
                        <li class="emph">See advanced statistics</li>
                        <li>Custom filtering, and personal progress tracking. With provided identity, you will be able also to give and receive kudos for nice media!</li>
                    </ul>
                </div>
            </div>
        </div>
    </div>

    <div class="page-card-2-bottom-info">
        <h2>Be fair and reliable!</h2>
        <p>
            Every second counts, but honesty comes first. All submissions are reviewed by our moderation
            team based on provided screenshots or replays. Right after upload your time entry
            it will display as not verified and highlighted on red. You need to wait for an approve
            until your time will become green and points will be recalculated.
        </p>
    </div>
   
</div>

<script>

    function observeMid(element, dotNetObjRef) {

        debugger;
        const observer = new IntersectionObserver(
            async ([e]) => {
                const isVisible = e.isIntersecting;
                const rect = e.boundingClientRect;

                if (isVisible) {
                    element.classList.add("touched");
                } else if (rect.top > 0) {
                    //element.classList.remove("touched");
                }
            },
            { threshold: [0, 0.1] });

        observer.observe(element);
    }

</script>

@code {

    @inject IJSRuntime JSRuntime;
    public ElementReference midElement;

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var reference = DotNetObjectReference.Create(this);
            await JSRuntime.InvokeVoidAsync("observeMid", midElement, reference);
        }
    }


}